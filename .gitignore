# #######################################################
# FarmFlow Root .gitignore
# #######################################################

# Dependency directories (extremely important to ignore!)
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment / Secret files (CRITICAL: Do not commit these to GitHub)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Production / Build outputs
dist/
dist-ssr/
frontend/dist/
frontend/dist-ssr/
build/
out/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend/logs/

# Coverage and testing
coverage/
.nyc_output/
*.lcov

# IDEs, Editors, and OS files
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
.idea/
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# TypeScript Cache
*.tsbuildinfo
